<UserControl x:Class="PdfToolkit.UI.Views.WatermarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Marca de agua" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,24"/>

            <!-- Selector de archivo -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Archivo PDF" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SourceFile, TargetNullValue='(ninguno seleccionado)'}"
                                   FontSize="13" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Seleccionar PDF"
                            Command="{Binding SelectSourceCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="16,10" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- InfoBar -->
            <Border Grid.Row="3" Style="{StaticResource InfoBarStyle}"
                    Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Abrir archivo"
                            Command="{Binding OpenResultCommand}"
                            Padding="14,6" Margin="8,0,0,0"
                            Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Grid.Column="2" Content="✕"
                            Command="{Binding CloseInfoBarCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8" Margin="4,0,0,0"/>
                </Grid>
            </Border>

            <!-- Opciones de marca de agua -->
            <Border Grid.Row="4"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Texto de la marca de agua" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="Ej. CONFIDENCIAL"
                             Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Textos predefinidos" Style="{StaticResource SectionLabelStyle}"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="CONFIDENCIAL"
                                Command="{Binding SetPresetCommand}" CommandParameter="CONFIDENCIAL"
                                Padding="12,6" Margin="0,0,8,6"/>
                        <Button Content="BORRADOR"
                                Command="{Binding SetPresetCommand}" CommandParameter="BORRADOR"
                                Padding="12,6" Margin="0,0,8,6"/>
                        <Button Content="COPIA"
                                Command="{Binding SetPresetCommand}" CommandParameter="COPIA"
                                Padding="12,6" Margin="0,0,8,6"/>
                        <Button Content="SOLO LECTURA"
                                Command="{Binding SetPresetCommand}" CommandParameter="SOLO LECTURA"
                                Padding="12,6" Margin="0,0,0,6"/>
                    </WrapPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}">
                                <Run Text="Tamaño de fuente: "/>
                                <Run Text="{Binding FontSize, StringFormat='{}{0:F0} pt'}"/>
                            </TextBlock>
                            <Slider Minimum="16" Maximum="120"
                                    Value="{Binding FontSize}"
                                    TickFrequency="4" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionLabelStyle}">
                            <Run Text="Opacidad: "/>
                            <Run Text="{Binding Opacity, StringFormat='{}{0} %'}"/>
                        </TextBlock>
                        <Slider Minimum="10" Maximum="100"
                                Value="{Binding Opacity}"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionLabelStyle}">
                            <Run Text="Ángulo: "/>
                            <Run Text="{Binding AngleDegrees, StringFormat='{}{0:F0}°'}"/>
                        </TextBlock>
                        <Slider Minimum="-90" Maximum="0"
                                Value="{Binding AngleDegrees}"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                    </StackPanel>

                    <TextBlock Text="Color (hex)" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="#808080"
                             Padding="10,8" Width="150" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Botones -->
            <Grid Grid.Row="5" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Padding="16,10" Margin="0,0,8,0"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Grid.Column="2" Content="Aplicar marca de agua"
                        Command="{Binding WatermarkCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="20,10"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
