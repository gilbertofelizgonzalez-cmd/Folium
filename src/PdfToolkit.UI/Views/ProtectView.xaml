<UserControl x:Class="PdfToolkit.UI.Views.ProtectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Proteger PDF" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,24"/>

        <!-- Selector de archivo -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Archivo PDF" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SourceFile, TargetNullValue='(ninguno seleccionado)'}"
                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Seleccionar PDF"
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,10" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- InfoBar -->
        <Border Grid.Row="3" Style="{StaticResource InfoBarStyle}"
                Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Abrir archivo"
                        Command="{Binding OpenResultCommand}"
                        Padding="14,6" Margin="8,0,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding CloseInfoBarCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Selector de modo -->
        <Border Grid.Row="4"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Operación" Style="{StaticResource SectionLabelStyle}"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Proteger con contraseña" IsChecked="{Binding ModeProtect}" Margin="0,0,24,0"/>
                    <RadioButton Content="Quitar contraseña" IsChecked="{Binding ModeUnprotect}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Formulario dinámico según el modo -->
        <Border Grid.Row="5"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20"
                VerticalAlignment="Top">
            <Grid>
                <!-- Panel PROTEGER -->
                <StackPanel Visibility="{Binding IsProtectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Contraseña de apertura" Style="{StaticResource SectionLabelStyle}"/>
                    <PasswordBox x:Name="UserPwBox"
                                 ui:ControlHelper.PlaceholderText="Contraseña para abrir el PDF"
                                 Padding="10,8" Margin="0,0,0,16"/>

                    <TextBlock Text="Contraseña de propietario (opcional)" Style="{StaticResource SectionLabelStyle}"/>
                    <PasswordBox x:Name="OwnerPwBox"
                                 ui:ControlHelper.PlaceholderText="Controla permisos de edición/impresión"
                                 Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12" LineHeight="18">
                        Se aplicará cifrado de 128 bits (RC4). La contraseña de apertura
                        es requerida para ver el documento. La de propietario restringe
                        operaciones como imprimir, copiar o editar el contenido.
                    </TextBlock>
                </StackPanel>

                <!-- Panel DESBLOQUEAR -->
                <StackPanel Visibility="{Binding IsUnprotectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Contraseña actual del PDF" Style="{StaticResource SectionLabelStyle}"/>
                    <PasswordBox x:Name="RemovePwBox"
                                 ui:ControlHelper.PlaceholderText="Introduce la contraseña para desbloquear"
                                 Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12" LineHeight="18">
                        Introduce la contraseña actual del PDF para eliminar la protección
                        y guardar una copia sin cifrado.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Botones -->
        <Grid Grid.Row="6" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    Padding="16,10" Margin="0,0,8,0"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Grid.Column="2"
                    Command="{Binding ExecuteCommand}"
                    Padding="20,10">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Setter Property="Content" Value="Proteger PDF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUnprotectMode}" Value="True">
                                <Setter Property="Content" Value="Quitar contraseña"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</UserControl>
