<UserControl x:Class="PdfToolkit.UI.Views.ConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:PdfToolkit.UI.ViewModels"
             xmlns:models="clr-namespace:PdfToolkit.UI.Models">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormatBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A0078D4"/>
            <Setter Property="BorderBrush" Value="#330078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>

        <Style x:Key="DocBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A2E7D32"/>
            <Setter Property="BorderBrush" Value="#332E7D32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="160"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Convertir a PDF" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,16"/>

            <!-- Converter status banner -->
            <Border Grid.Row="2" Padding="12,10" CornerRadius="4" BorderThickness="1" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1A2E7D32"/>
                        <Setter Property="BorderBrush" Value="#332E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasDocumentConverter}" Value="False">
                                <Setter Property="Background" Value="#1AF57C00"/>
                                <Setter Property="BorderBrush" Value="#33F57C00"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="✅"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDocumentConverter}" Value="False">
                                        <Setter Property="Text" Value="⚠️"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ConverterStatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.85"/>
                </StackPanel>
            </Border>

            <!-- Formatos — Imágenes -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <TextBlock Text="Imágenes admitidas" Opacity="0.5" FontSize="11" Margin="0,0,0,6"/>
                <WrapPanel Orientation="Horizontal">
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="JPG/JPEG" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="PNG" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="BMP" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="GIF" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="TIFF" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="WebP" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="HEIC/HEIF" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="ICO" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="WMF/EMF" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <Border Style="{StaticResource FormatBadgeStyle}"><TextBlock Text="TGA/PSD/PCX" FontSize="11" FontWeight="SemiBold" Foreground="#0078D4"/></Border>
                    <TextBlock Text="(TIFF/GIF multi-frame: cada fotograma = 1 página)" Opacity="0.4" FontSize="11" VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>

            <!-- Formatos — Documentos -->
            <StackPanel Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Text="Documentos admitidos" Opacity="0.5" FontSize="11" Margin="0,0,0,6"/>
                <WrapPanel Orientation="Horizontal">
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="DOCX/DOC" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="PPTX/PPT" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="XLSX/XLS" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="ODT/ODP/ODS" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="RTF/TXT" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                    <Border Style="{StaticResource DocBadgeStyle}"><TextBlock Text="HTML/CSV" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/></Border>
                </WrapPanel>
            </StackPanel>

            <!-- InfoBar -->
            <Border Grid.Row="5"
                    Style="{StaticResource InfoBarStyle}"
                    Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕"
                            Command="{Binding CloseInfoBarCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- Lista de archivos -->
            <Border Grid.Row="6" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" CornerRadius="4">
                <ListBox ItemsSource="{Binding SourceFiles}"
                         AllowDrop="False"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PdfFileItem}">
                            <Grid Height="64" Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icono / previsualización -->
                                <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                                        CornerRadius="4"
                                        Margin="0,0,12,0"
                                        ClipToBounds="True">
                                    <Image Source="{Binding FilePath}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding FilePath}"
                                               FontSize="11"
                                               Opacity="0.45"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="▲" Width="32" Height="32" Margin="2,0"
                                            ToolTip="Mover arriba"
                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="▼" Width="32" Height="32" Margin="2,0"
                                            ToolTip="Mover abajo"
                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="✕" Width="32" Height="32" Margin="2,0"
                                            ToolTip="Eliminar"
                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Progreso -->
            <StackPanel Grid.Row="7" Margin="0,16,0,0"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="{Binding CurrentFileName, StringFormat='Convirtiendo: {0}'}" Opacity="0.7"/>
                    <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}{0:F0}%'}"
                               HorizontalAlignment="Right" Opacity="0.7"/>
                </Grid>
                <ProgressBar Height="6" Value="{Binding ProgressPercentage}" Maximum="100"/>
            </StackPanel>

            <!-- Botones -->
            <Grid Grid.Row="8" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Agregar archivos"
                            Command="{Binding SelectFilesCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="20,10"/>
                    <Button Content="Limpiar lista"
                            Command="{Binding ClearAllCommand}"
                            Padding="20,10" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancelar"
                            Command="{Binding CancelConvertCommand}"
                            Padding="20,10" Margin="0,0,8,0"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Convertir a PDF"
                            Command="{Binding ConvertToPdfCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="20,10"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
