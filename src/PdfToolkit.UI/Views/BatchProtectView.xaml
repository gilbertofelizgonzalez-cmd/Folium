<UserControl x:Class="PdfToolkit.UI.Views.BatchProtectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Borde de cada tarjeta del panel derecho -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Botón secundario de acción (uniforme con los demás) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <!-- ScrollViewer exterior para ventanas pequeñas -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid Margin="24" MinHeight="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- título -->
                <RowDefinition Height="Auto"/>  <!-- subtítulo -->
                <RowDefinition Height="Auto"/>  <!-- InfoBar -->
                <RowDefinition Height="Auto"/>  <!-- progreso -->
                <RowDefinition Height="Auto" MinHeight="320"/>  <!-- contenido principal -->
                <RowDefinition Height="Auto"/>  <!-- botones inferiores -->
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0" Text="Cifrado" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,20"/>

            <!-- InfoBar -->
            <Border Grid.Row="2" Style="{StaticResource InfoBarStyle}"
                    Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap"
                                   Opacity="0.85" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Abrir carpeta"
                            Command="{Binding OpenResultFolderCommand}"
                            Padding="12,6" Margin="8,0,4,0"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Grid.Column="2" Content="Exportar contraseñas"
                            Command="{Binding ExportPasswordListCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="12,6" Margin="0,0,4,0"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Grid.Column="3" Content="✕"
                            Command="{Binding CloseInfoBarCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8"/>
                </Grid>
            </Border>

            <!-- Barra de progreso -->
            <StackPanel Grid.Row="3" Margin="0,0,0,16"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="{Binding ProgressText}" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                    <TextBlock HorizontalAlignment="Right" Opacity="0.7">
                        <Run Text="{Binding ProgressValue}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding ProgressMax}"/>
                    </TextBlock>
                </Grid>
                <ProgressBar Height="6" Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"/>
            </StackPanel>

            <!-- ─── Contenido principal: lista (izq) + opciones (der) ─── -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <!-- Lista de archivos: crece con la ventana -->
                    <ColumnDefinition Width="*" MinWidth="220"/>
                    <!-- Separador -->
                    <ColumnDefinition Width="16"/>
                    <!-- Panel de opciones: ancho fijo pero adaptable -->
                    <ColumnDefinition Width="280" MinWidth="240" MaxWidth="340"/>
                </Grid.ColumnDefinitions>

                <!-- ── Lista de archivos ── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1" CornerRadius="6"
                        MinHeight="320">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Barra de herramientas -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Padding="12,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="+ Agregar archivos"
                                            Command="{Binding AddFilesCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="12,6" Margin="0,0,8,0"/>
                                    <Button Content="+ Carpeta"
                                            Command="{Binding AddFolderCommand}"
                                            Padding="12,6"/>
                                </StackPanel>
                                <Button Content="Limpiar lista"
                                        Command="{Binding ClearListCommand}"
                                        HorizontalAlignment="Right" Padding="10,6"
                                        Visibility="{Binding HasFiles,
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Estado vacío -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HasNoFiles,
                                        Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="Agrega PDFs o una carpeta" Opacity="0.4"
                                       Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Elementos -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasFiles,
                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding Files}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                BorderThickness="0,0,0,1" Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                                           FontSize="16" VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="11" Opacity="0.55" Margin="0,2,0,0"
                                                               Visibility="{Binding Password,
                                                                   Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Run Text="🔑 "/>
                                                        <Run Text="{Binding Password}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                                           FontSize="11" Opacity="0.6"
                                                           VerticalAlignment="Center" Margin="8,0,8,0"/>

                                                <Button Grid.Column="3" Content="✕"
                                                        Command="{Binding DataContext.RemoveFileCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="6" VerticalAlignment="Center" Opacity="0.6"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── Panel de opciones (con ScrollViewer propio) ── -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Modo de contraseña -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="MODO DE CONTRASEÑA" Style="{StaticResource SectionLabel}"/>
                                <RadioButton Content="Contraseña única por archivo"
                                             IsChecked="{Binding ModeUniquePerFile}"
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="Misma contraseña para todos"
                                             IsChecked="{Binding ModeSameForAll}"/>

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding ModeSameForAll,
                                                Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Contraseña común" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding CommonPassword, UpdateSourceTrigger=PropertyChanged}"
                                             ui:ControlHelper.PlaceholderText="Dejar vacío para generar"
                                             Padding="10,8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Generador -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="GENERADOR" Style="{StaticResource SectionLabel}"/>

                                <!-- Longitud -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Longitud" VerticalAlignment="Center" FontSize="13"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="−" Padding="10,4"
                                                Command="{Binding DecreaseLengthCommand}"/>
                                        <TextBlock Text="{Binding PwLength}" Width="30"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="14" FontWeight="SemiBold"/>
                                        <Button Content="+" Padding="10,4"
                                                Command="{Binding IncreaseLengthCommand}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Caracteres — 2×2 uniforme -->
                                <TextBlock Text="Caracteres" FontSize="12" Opacity="0.6" Margin="0,0,0,8"/>
                                <UniformGrid Rows="2" Columns="2" Margin="0,0,0,14">
                                    <CheckBox Content="Mayúsculas" IsChecked="{Binding PwUpper}"  Margin="0,0,0,6"/>
                                    <CheckBox Content="Minúsculas" IsChecked="{Binding PwLower}"  Margin="0,0,0,6"/>
                                    <CheckBox Content="Números"    IsChecked="{Binding PwDigits}"/>
                                    <CheckBox Content="Símbolos"   IsChecked="{Binding PwSymbols}"/>
                                </UniformGrid>

                                <!-- Contraseña de ejemplo -->
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                        CornerRadius="4" Padding="10,9" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="{Binding PasswordPreview}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Pulsa «Vista previa» para generar..."
                                                   Opacity="0.4" FontSize="12" VerticalAlignment="Center"
                                                   Visibility="{Binding HasNoPasswordPreview,
                                                       Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <Button Content="Vista previa"
                                        Command="{Binding GeneratePreviewCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,8"/>
                            </StackPanel>
                        </Border>

                        <!-- Acciones -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="ACCIONES" Style="{StaticResource SectionLabel}"/>

                                <Button Content="Generar contraseñas"
                                        Command="{Binding AssignPasswordsCommand}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,10" Margin="0,0,0,8"
                                        Visibility="{Binding HasFiles,
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Button Content="Copiar lista de contraseñas"
                                        Command="{Binding CopyPasswordListCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,10" Margin="0,0,0,8"
                                        Visibility="{Binding HasFiles,
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Button Content="Exportar contraseñas (CSV)"
                                        Command="{Binding ExportPasswordListCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,10"
                                        Visibility="{Binding HasFiles,
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- ─── Botones inferiores ─── -->
            <Grid Grid.Row="5" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Padding="16,10" Margin="0,0,8,0"
                        Visibility="{Binding IsProcessing,
                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Grid.Column="2" Content="Cifrar todos"
                        Command="{Binding EncryptAllCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="24,10"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
