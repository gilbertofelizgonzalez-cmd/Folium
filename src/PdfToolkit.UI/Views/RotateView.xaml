<UserControl x:Class="PdfToolkit.UI.Views.RotateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rotar páginas" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,24"/>

        <!-- Selector de archivo -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Archivo PDF" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SourceFile, TargetNullValue='(ninguno seleccionado)'}"
                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Seleccionar PDF"
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,10" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- InfoBar -->
        <Border Grid.Row="3" Style="{StaticResource InfoBarStyle}"
                Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Abrir archivo"
                        Command="{Binding OpenResultCommand}"
                        Padding="14,6" Margin="8,0,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding CloseInfoBarCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Opciones de rotación y selección -->
        <Border Grid.Row="4"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ángulo de rotación" Opacity="0.6" FontSize="12" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="90° →"
                                     IsChecked="{Binding Rotation90}"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="180°"
                                     IsChecked="{Binding Rotation180}"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="← 270°"
                                     IsChecked="{Binding Rotation270}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Seleccionar todas"
                            Command="{Binding SelectAllCommand}"
                            Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="Ninguna"
                            Command="{Binding SelectNoneCommand}"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lista de páginas -->
        <Border Grid.Row="5"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="16">
            <Grid>
                <TextBlock Text="Selecciona un PDF para ver sus páginas."
                           Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasNoPages, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasPages, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Pages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" Padding="10,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#150078D4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Command="{Binding DataContext.PageSelectionChangedCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <!-- Thumbnail with rotation preview -->
                                        <Border Grid.Column="1" Width="120" Height="160"
                                                ClipToBounds="True" CornerRadius="3"
                                                Background="#FF3C3C3C"
                                                Margin="0,0,14,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <!-- Thumbnail image — fills container, rotates with preview -->
                                                <Image Source="{Binding Thumbnail}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       Stretch="Uniform"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Image.RenderTransform>
                                                        <RotateTransform Angle="{Binding PreviewRotation}"/>
                                                    </Image.RenderTransform>
                                                </Image>
                                                <!-- Rotation arrow badge (only on selected pages) -->
                                                <Border Background="#DD0078D4" CornerRadius="3,0,0,0"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Padding="6,3"
                                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding RotationArrow}"
                                                               Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Page number + rotation info -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PageNumber, StringFormat='Página {0}'}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,4,0,0" FontSize="12" Opacity="0.6"
                                                       Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Run Text="Girar "/>
                                                <Run Text="{Binding PreviewRotation, StringFormat='{}{0}°'}"
                                                     Foreground="#FF0078D4" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Rotation label -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding RotationArrow}"
                                                   FontSize="22" VerticalAlignment="Center"
                                                   Foreground="#FF0078D4" Margin="8,0,0,0"
                                                   Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Botones -->
        <Grid Grid.Row="6" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    Padding="16,10" Margin="0,0,8,0"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Grid.Column="2" Content="Rotar páginas"
                    Command="{Binding RotateCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="20,10"/>
        </Grid>
    </Grid>
</UserControl>
