<UserControl x:Class="PdfToolkit.UI.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A1976D2"/>
            <Setter Property="BorderBrush" Value="#331976D2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Success">
                    <Setter Property="Background" Value="#1A2E7D32"/>
                    <Setter Property="BorderBrush" Value="#332E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Warning">
                    <Setter Property="Background" Value="#1AF57C00"/>
                    <Setter Property="BorderBrush" Value="#33F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding InfoBarSeverity}" Value="Error">
                    <Setter Property="Background" Value="#1AC62828"/>
                    <Setter Property="BorderBrush" Value="#33C62828"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PDF a imágenes" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,0,0,24"/>

        <!-- Selector de archivo -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Archivo PDF" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SourceFile, TargetNullValue='(ninguno seleccionado)'}"
                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Seleccionar PDF"
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,10" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- InfoBar -->
        <Border Grid.Row="3" Style="{StaticResource InfoBarStyle}"
                Visibility="{Binding IsInfoBarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding InfoBarTitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding InfoBarMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Abrir carpeta"
                        Command="{Binding OpenResultCommand}"
                        Padding="14,6" Margin="8,0,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding CloseInfoBarCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Progreso -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="0,0,0,4">
                <TextBlock Text="{Binding CurrentFileName, StringFormat='Exportando: {0}'}" Opacity="0.7"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}{0:F0}%'}"
                           HorizontalAlignment="Right" Opacity="0.7"/>
            </Grid>
            <ProgressBar Height="6" Value="{Binding ProgressPercentage}" Maximum="100"/>
        </StackPanel>

        <!-- Opciones de formato y resolución -->
        <Border Grid.Row="5"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Formato -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Formato de imagen" Opacity="0.6" FontSize="12" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="JPG" IsChecked="{Binding FormatJpg}" Margin="0,0,16,0"/>
                        <RadioButton Content="PNG" IsChecked="{Binding FormatPng}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Separador vertical -->
                <Border Grid.Column="1" Width="1"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        Margin="20,0"/>

                <!-- Resolución -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Resolución (DPI)" Opacity="0.6" FontSize="12" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="72 dpi" IsChecked="{Binding Dpi72}" Margin="0,0,12,0"/>
                        <RadioButton Content="150 dpi" IsChecked="{Binding Dpi150}" Margin="0,0,12,0"/>
                        <RadioButton Content="300 dpi" IsChecked="{Binding Dpi300}" Margin="0,0,12,0"/>
                        <RadioButton Content="600 dpi" IsChecked="{Binding Dpi600}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Páginas a exportar -->
        <Border Grid.Row="6"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Páginas a exportar" Opacity="0.6" FontSize="12" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="Todas las páginas" IsChecked="{Binding ExportAllPages}" Margin="0,0,24,0"/>
                    <RadioButton Content="Páginas específicas" IsChecked="{Binding ExportSpecificPages}"/>
                </StackPanel>
                <Grid Visibility="{Binding ExportSpecificPages, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding PageRangeText, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="Ej: 1,3,5-8,10"
                             Padding="10,8"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalPageCount, StringFormat='de {0} pág.'}"
                               Opacity="0.6" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding HasPageCount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Botones -->
        <Grid Grid.Row="7" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    Padding="16,10" Margin="0,0,8,0"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Grid.Column="2" Content="Exportar imágenes"
                    Command="{Binding ExportCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="20,10"/>
        </Grid>
    </Grid>
</UserControl>
