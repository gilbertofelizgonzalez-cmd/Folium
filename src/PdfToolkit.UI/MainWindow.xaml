<Window x:Class="PdfToolkit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:PdfToolkit.UI.ViewModels"
        xmlns:views="clr-namespace:PdfToolkit.UI.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding Title}"
        Icon="pack://application:,,,/Resources/app.ico"
        Height="750" Width="1100"
        MinHeight="500" MinWidth="800">
    <Window.Resources>
        <!-- Botón de nav: texto y fondo siguen el tema automáticamente -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,24,0,16">
                    <TextBlock Text="Folium"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="20,0,20,6"/>
                    <TextBlock Text="Herramientas PDF"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="20,0,20,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="FUNCIONES"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                               Margin="20,8,20,8"/>
                    <Button Command="{Binding NavigateMergeCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Merge">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Unir PDFs" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateSplitCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Split">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Dividir PDF" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateConvertCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Convert">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Convertir a PDF" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateCompressCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Compress">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Comprimir PDF" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateRotateCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Rotate">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Rotar páginas" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateOrganizeCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Organize">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Reorganizar páginas" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateWatermarkCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Watermark">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Marca de agua" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateExportCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Export">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="PDF a imágenes" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateBatchProtectCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="BatchProtect">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Cifrado" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding NavigateDecryptCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Decrypt">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Quitar contraseña" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <Border Height="1"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            Margin="12,0,12,8"/>
                    <Button Command="{Binding NavigateSettingsCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePage}" Value="Settings">
                                        <Setter Property="Background" Value="#330078D4"/>
                                        <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                        <Setter Property="Foreground" Value="{x:Static SystemColors.HighlightTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Ajustes" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:MergeViewModel}">
                    <views:MergeView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SplitViewModel}">
                    <views:SplitView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ConvertViewModel}">
                    <views:ConvertView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:CompressViewModel}">
                    <views:CompressView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:RotateViewModel}">
                    <views:RotateView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ExportViewModel}">
                    <views:ExportView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BatchProtectViewModel}">
                    <views:BatchProtectView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:OrganizeViewModel}">
                    <views:OrganizeView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:WatermarkViewModel}">
                    <views:WatermarkView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DecryptViewModel}">
                    <views:DecryptView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
